#!/usr/bin/env python3

import fileinput
import re


def hide_secrets(line):
    secret_pattern = re.compile(
        r"(?i)((?:password|secret|api[_-]?key|token|key|credential)[\s:=]+)" r'(?:(["\'])(.+?)\2|(\S+))'
    )

    def replace_with_x(match):
        prefix = match.group(1)
        if match.group(2):  # quoted value
            quote = match.group(2)
            value = match.group(3)
            return prefix + quote + "X" * len(value) + quote
        else:  # unquoted value
            value = match.group(4)
            return prefix + "X" * len(value)

    return secret_pattern.sub(replace_with_x, line)


if __name__ == "__main__":
    for line in fileinput.input():
        print(hide_secrets(line), end="")
