#!/bin/sh
# Helper proxy to resolve incus container name to IP and forward TCP
# Usage: incus-proxy <host> <port>

# Create an entry in your ~/.ssh/config with:
#
# Host incus-*
#     ProxyCommand /home/wwuh8r/.ssh/incus-proxy %h %p


host="$1"
port="$2"
name="${host#incus-}"
ip=$(incus info "$name" | yq -r '.Resources."Network usage".eth0."IP addresses".inet' | grep -o -E '[0-9]{1,3}(\.[0-9]{1,3}){3}' | head -n1)
if [ -z "$ip" ]; then
  echo "incus-proxy: failed to resolve IP for '$name'" >&2
  exit 255
fi
exec nc "$ip" "$port"
